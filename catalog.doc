<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>TAROT CLUB – Irresistible Fashion at Irresistible Prices</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet">
  <style>
    :root{--black:#000;--dark:#111;--gray:#333;--light:#f8f8f8;--white:#fff;--accent:#c00;--primary:#000}
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Inter',sans-serif;background:var(--white);color:var(--gray);line-height:1.6;user-select:none;-webkit-tap-highlight-color:transparent}
    a{color:var(--primary);text-decoration:none}
    header{position:fixed;top:0;left:0;right:0;background:var(--white);border-bottom:1px solid #eee;z-index:100;padding:1rem 5%;display:flex;justify-content:space-between;align-items:center;box-shadow:0 2px 10px rgba(0,0,0,.05)}
    .logo{font-size:1.8rem;font-weight:900;text-transform:uppercase;letter-spacing:1px;color:var(--primary)}
    nav ul{display:flex;gap:2.5rem;font-weight:600;text-transform:uppercase;font-size:.95rem}
    nav ul li a{transition:color .3s}
    nav ul li a:hover{color:var(--accent)}
    .icons{display:flex;gap:1.5rem;font-size:1.4rem}
    .cart-icon{position:relative;cursor:pointer}
    .cart-icon::after{content:attr(data-count);position:absolute;top:-8px;right:-10px;background:var(--accent);color:var(--white);font-size:.7rem;padding:.2rem .5rem;border-radius:50%}
    main{padding-top:80px}
    .hero{height:80vh;background:linear-gradient(rgba(0,0,0,.3),rgba(0,0,0,.2)),url('https://images.unsplash.com/photo-1483985988355-763728e1935b?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80') center/cover no-repeat;color:var(--white);display:flex;align-items:center;justify-content:center;text-align:center}
    .hero h1{font-size:4rem;font-weight:900;text-transform:uppercase;margin-bottom:1rem}
    .hero p{font-size:1.6rem;margin-bottom:2.5rem}
    .cta{background:var(--primary);color:var(--white);padding:1.2rem 3rem;font-weight:700;text-transform:uppercase;border:none;cursor:pointer;transition:all .3s}
    .cta:hover{background:#222}
    .section{padding:6rem 5%;background:var(--light)}
    .section:nth-child(even){background:var(--white)}
    .section-title{text-align:center;font-size:2.8rem;font-weight:900;text-transform:uppercase;margin-bottom:3rem;letter-spacing:1px;color:var(--primary)}
    .product-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:2.5rem}
    .product-card{background:var(--white);border:1px solid #eee;overflow:hidden;transition:transform .3s,box-shadow .3s;position:relative}
    .product-card:hover{transform:translateY(-10px);box-shadow:0 15px 30px rgba(0,0,0,.1)}
    .product-image{width:100%;height:400px;object-fit:cover}
    .product-info{padding:1.5rem;text-align:center}
    .product-name{font-size:1.2rem;font-weight:700;margin-bottom:.5rem;text-transform:uppercase}
    .product-desc{font-size:.95rem;color:#666;margin-bottom:1rem;line-height:1.5}
    .product-price{font-size:1.3rem;font-weight:800;color:var(--dark);margin-bottom:1.2rem}
    .add-btn{background:var(--primary);color:var(--white);width:100%;padding:.9rem;border:none;font-weight:700;text-transform:uppercase;cursor:pointer;transition:background .3s}
    .add-btn:hover{background:#222}
    .modal{position:fixed;inset:0;background:rgba(0,0,0,.7);display:none;align-items:center;justify-content:center;z-index:200}
    .modal-content{background:var(--white);width:90%;max-width:500px;padding:2.5rem;border-radius:8px;max-height:85vh;overflow-y:auto}
    .close-modal{position:absolute;top:1rem;right:1.5rem;font-size:2.5rem;cursor:pointer}
    .cart-item{display:flex;justify-content:space-between;padding:1rem 0;border-bottom:1px solid #eee;font-size:1.1rem}
    footer{background:var(--primary);color:var(--light);padding:3rem 5%;text-align:center}
    .footer-links{display:flex;justify-content:center;gap:2rem;margin-bottom:1.5rem;flex-wrap:wrap}
    .footer-links a{color:var(--light);font-weight:500}
    @media (max-width:768px){header{flex-direction:column;padding:1rem;gap:1rem}nav ul{flex-direction:column;gap:1rem;text-align:center}.hero h1{font-size:3rem}.section{padding:4rem 4%}}
  </style>
</head>
<body>

<header>
  <div class="logo">TAROT CLUB</div>
  <nav><ul><li><a href="#">Women</a></li><li><a href="#">Men</a></li><li><a href="#">Kids</a></li><li><a href="#">Footwear</a></li><li><a href="#">Sale</a></li></ul></nav>
  <div class="icons"><div class="cart-icon" data-count="0" onclick="toggleCart()">🛒</div></div>
</header>

<main>
  <section class="hero">
    <div>
      <h1>TAROT CLUB</h1>
      <p>Irresistible Fashion at Irresistible Prices</p>
      <button class="cta">SHOP NOW</button>
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">Featured Footwear</h2>
    <div class="product-grid">
      <div class="product-card">
        <img class="product-image" src="https://images.unsplash.com/photo-1605733513502-0e2c0d703e5d?w=800" alt="Running Shoes">
        <div class="product-info">
          <div class="product-name">Aura Performance Running</div>
          <div class="product-desc">Breathable mesh upper, responsive cushioning, durable rubber outsole. Ideal for daily runs and gym. Sizes 6-12.</div>
          <div class="product-price">₹5,999</div>
          <button class="add-btn" onclick="addToCart('Aura Performance Running',5999)">Add to Cart</button>
        </div>
      </div>
      <!-- Add your other 20+ products here the same way -->
    </div>
  </section>
</main>

<div class="modal" id="cartModal">
  <div class="modal-content">
    <span class="close-modal" onclick="toggleCart()">&times;</span>
    <h2>Your Cart</h2>
    <div id="cartItems"></div>
    <p>Total: <span id="cartTotal">₹0</span></p>
    <button class="cta">Checkout</button>
  </div>
</div>

<footer>
  <div class="footer-links">
    <a href="#">About Us</a><a href="#">Privacy Policy</a><a href="#">Returns</a>
  </div>
  <p>© 2026 Tarot Club</p>
</footer>

<script>
let cart=JSON.parse(localStorage.getItem('cart'))||[];const cartIcon=document.querySelector('.cart-icon'),modal=document.getElementById('cartModal'),itemsDiv=document.getElementById('cartItems'),totalEl=document.getElementById('cartTotal');
function addToCart(n,p){cart.push({name:n,price:p});localStorage.setItem('cart',JSON.stringify(cart));updateCart()}
function updateCart(){cartIcon.dataset.count=cart.length;itemsDiv.innerHTML='';let t=0;cart.forEach(i=>{t+=i.price;let d=document.createElement('div');d.className='cart-item';d.innerHTML=`<span>\( {i.name}</span><span>₹ \){i.price.toLocaleString('en-IN')}</span>`;itemsDiv.appendChild(d)});totalEl.textContent=`₹${t.toLocaleString('en-IN')}`}
function toggleCart(){modal.style.display=modal.style.display==='flex'?'none':'flex'}
modal.addEventListener('click',e=>{if(e.target===modal)toggleCart()});updateCart();
</script>
</body>
</html>
